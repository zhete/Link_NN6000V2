#!/bin/sh
#===============================================================================
# 991_custom_settings - System Custom Settings
# 
# 功能：系统启动时的自定义配置
# 优化：改进错误处理、减少重复操作、优化日志输出
#===============================================================================

#-------------------------------------------------------------------------------
# 配置参数
#-------------------------------------------------------------------------------
CONNTRACK_MAX=65535
DROPBEAR_CONFIG="dropbear.main"

#-------------------------------------------------------------------------------
# 辅助函数：输出日志
#-------------------------------------------------------------------------------
log_info() {
    echo "[INFO] $*"
}

log_error() {
    echo "[ERROR] $*" >&2
}

#-------------------------------------------------------------------------------
# 配置 nf_conntrack_max（最大连接跟踪数）
#-------------------------------------------------------------------------------
configure_conntrack() {
    local current_value
    local sysctl_conf="/etc/sysctl.conf"
    local conf_key="net.netfilter.nf_conntrack_max"
    
    # 检查 sysctl 是否支持该参数
    if ! sysctl -n "$conf_key" >/dev/null 2>&1; then
        log_error "系统不支持 $conf_key 参数，跳过配置"
        return 1
    fi
    
    # 获取当前值
    current_value=$(sysctl -n "$conf_key" 2>/dev/null)
    
    # 验证获取的值是否有效
    if [ -z "$current_value" ] || ! [ "$current_value" -gt 0 ] 2>/dev/null; then
        log_error "无法获取有效的 $conf_key 当前值"
        return 1
    fi
    
    # 如果当前值已大于等于目标值，无需修改
    if [ "$current_value" -ge "$CONNTRACK_MAX" ]; then
        log_info "nf_conntrack_max 当前值 ($current_value) 已满足要求"
        return 0
    fi
    
    log_info "当前 nf_conntrack_max=$current_value，目标值=$CONNTRACK_MAX，正在更新..."
    
    # 清理旧的配置
    if [ -f "$sysctl_conf" ]; then
        sed -i "/${conf_key}/d" "$sysctl_conf"
    fi
    
    # 添加新配置
    echo "${conf_key} = ${CONNTRACK_MAX}" >> "$sysctl_conf"
    
    # 应用配置
    if sysctl -p >/dev/null 2>&1; then
        log_info "nf_conntrack_max 已更新为 $CONNTRACK_MAX"
        return 0
    else
        log_error "应用 sysctl 配置失败"
        return 1
    fi
}

#-------------------------------------------------------------------------------
# 配置 ZeroTier 防火墙规则
#-------------------------------------------------------------------------------
configure_zerotier_firewall() {
    # 检查防火墙配置文件
    if [ ! -f "/etc/config/firewall" ]; then
        log_error "防火墙配置文件不存在"
        return 1
    fi
    
    # 检查是否已配置 ZeroTier 规则
    if uci show firewall | grep -q "zerotier"; then
        log_info "ZeroTier 防火墙规则已存在，跳过"
        return 0
    fi
    
    log_info "正在配置 ZeroTier 防火墙规则..."
    
    # 添加 ZeroTier 区域
    uci add firewall zone 2>/dev/null
    uci set firewall.@zone[-1].name='zerotier' 2>/dev/null
    uci set firewall.@zone[-1].input='ACCEPT' 2>/dev/null
    uci set firewall.@zone[-1].output='ACCEPT' 2>/dev/null
    uci set firewall.@zone[-1].forward='ACCEPT' 2>/dev/null
    uci set firewall.@zone[-1].masq='no' 2>/dev/null
    uci set firewall.@zone[-1].mtu_fix='0' 2>/dev/null
    uci set firewall.@zone[-1].network='zerotier' 2>/dev/null
    
    # 允许 ZeroTier 到 LAN 的转发
    uci add firewall forwarding 2>/dev/null
    uci set firewall.@forwarding[-1].src='zerotier' 2>/dev/null
    uci set firewall.@forwarding[-1].dest='lan' 2>/dev/null
    
    # 允许 LAN 到 ZeroTier 的转发
    uci add firewall forwarding 2>/dev/null
    uci set firewall.@forwarding[-1].src='lan' 2>/dev/null
    uci set firewall.@forwarding[-1].dest='zerotier' 2>/dev/null
    
    # 提交配置
    uci commit firewall 2>/dev/null || {
        log_error "提交 ZeroTier 防火墙配置失败"
        return 1
    }
    
    log_info "ZeroTier 防火墙规则配置完成"
    return 0
}

#-------------------------------------------------------------------------------
# 解除 dropbear SSH 访问限制
#-------------------------------------------------------------------------------
configure_dropbear() {
    local config_section="$DROPBEAR_CONFIG"
    
    # 检查 dropbear 配置是否存在
    if ! uci show "$config_section" >/dev/null 2>&1; then
        log_error "dropbear 配置不存在，跳过"
        return 1
    fi
    
    # 检查是否存在 DirectInterface 限制
    if ! uci show "$config_section" | grep -q "DirectInterface"; then
        log_info "dropbear 未设置 DirectInterface 限制"
        return 0
    fi
    
    log_info "正在解除 dropbear DirectInterface 访问限制..."
    
    # 删除限制配置
    if uci delete "${config_section}.DirectInterface" 2>/dev/null; then
        # 提交更改
        if uci commit "$config_section" 2>/dev/null; then
            # 重启 dropbear 服务
            if /etc/init.d/dropbear restart >/dev/null 2>&1; then
                log_info "dropbear 访问限制已解除，服务已重启"
                return 0
            else
                log_error "重启 dropbear 服务失败"
                return 1
            fi
        else
            log_error "提交 dropbear 配置失败"
            return 1
        fi
    else
        log_error "删除 DirectInterface 配置失败"
        return 1
    fi
}

#-------------------------------------------------------------------------------
# 网络优化配置
#-------------------------------------------------------------------------------
configure_network_optimization() {
    local sysctl_conf="/etc/sysctl.conf"
    
    log_info "正在应用网络优化配置..."
    
    # 清理旧的网络优化配置
    if [ -f "$sysctl_conf" ]; then
        sed -i '/^net\.netfilter\.nf_conntrack_tcp_timeout/d' "$sysctl_conf"
        sed -i '/^net\.ipv4\.tcp_/d' "$sysctl_conf"
        sed -i '/^net\.core\./d' "$sysctl_conf"
    fi
    
    # TCP 超时优化
    cat >> "$sysctl_conf" << 'EOF'

#========== 网络优化配置 ==========#
# TCP 连接超时优化
net.netfilter.nf_conntrack_tcp_timeout_established = 432000
net.netfilter.nf_conntrack_tcp_timeout_syn_recv = 120
net.netfilter.nf_conntrack_tcp_timeout_syn_sent = 120
net.netfilter.nf_conntrack_tcp_timeout_fin_wait = 120
net.netfilter.nf_conntrack_tcp_timeout_close_wait = 30
net.netfilter.nf_conntrack_tcp_timeout_time_wait = 60

# TCP 性能优化
net.ipv4.tcp_congestion_control = bbr
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_fin_timeout = 30
net.ipv4.tcp_keepalive_time = 600
net.ipv4.tcp_keepalive_probes = 5
net.ipv4.tcp_keepalive_intvl = 15
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_max_tw_buckets = 8192
net.ipv4.tcp_window_scaling = 1

# TCP 缓冲区优化
net.ipv4.tcp_rmem = 4096 87380 67108864
net.ipv4.tcp_wmem = 4096 65536 67108864
net.core.rmem_default = 262144
net.core.wmem_default = 262144
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216

# 网络队列和端口优化
net.core.netdev_max_backlog = 5000
net.core.somaxconn = 4096
net.ipv4.ip_local_port_range = 1024 65535
net.ipv4.tcp_max_syn_backlog = 8192

# NAT 优化
net.netfilter.nf_conntrack_expect_max = 8192
EOF
    
    # 应用配置
    if sysctl -p >/dev/null 2>&1; then
        log_info "网络优化配置已应用"
        return 0
    else
        log_error "应用网络优化配置失败"
        return 1
    fi
}

#-------------------------------------------------------------------------------
# 主函数
#-------------------------------------------------------------------------------
main() {
    log_info "开始应用自定义系统配置..."
    
    # 配置连接跟踪
    configure_conntrack
    
    # 配置 dropbear
    configure_dropbear
    
    # 配置 ZeroTier 防火墙规则
    configure_zerotier_firewall
    
    # 网络优化
    configure_network_optimization

    log_info "自定义配置应用完成"
}

# 执行主函数
main
